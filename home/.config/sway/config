### Misc

# Enable xwayland support
xwayland enable



### Input configuration

## Keyboard
input "type:keyboard" {
    xkb_layout us,ru
    # xkb_variant qwerty
    xkb_options grp:alt_shift_toggle
}

## Touchpad
input "10182:480:GXTP7863:00_27C6:01E0_Touchpad" {
        accel_profile adaptive
        click_method clickfinger
        drag enabled
        natural_scroll enabled
        pointer_accel 0.5
        scroll_method two_finger
        tap enabled
}

## USB mouse
input "1133:49298:Logitech_G203_LIGHTSYNC_Gaming_Mouse" {
    pointer_accel -0.4
}


## Mouse actions
focus_follows_mouse no

## Floating modifier
floating_modifier $mod normal



### Key bindings

bindsym --to-code {

##  Windows and workspaces

    # Focus windows
    $mod+j focus left
    $mod+k focus right
    $mod+l focus down      
    $mod+semicolon focus up

    # Moving windows
    $mod+Shift+j move left
    $mod+Shift+l move down     
    $mod+Shift+semicolon move up
    $mod+Shift+k move right

    # Switch to workspace
    $mod+1 workspace number 1
    $mod+2 workspace number 2
    $mod+3 workspace number 3
    $mod+4 workspace number 4
    $mod+5 workspace number 5
    $mod+6 workspace number 6
    $mod+7 workspace number 7
    $mod+8 workspace number 8
    $mod+9 workspace number 9
    $mod+0 workspace number 10

    # Last used workspace 
    $mod+Tab workspace back_and_forth

    # Move focused window to workspace
    $mod+Shift+1 move container to workspace number 1
    $mod+Shift+2 move container to workspace number 2
    $mod+Shift+3 move container to workspace number 3
    $mod+Shift+4 move container to workspace number 4
    $mod+Shift+5 move container to workspace number 5
    $mod+Shift+6 move container to workspace number 6
    $mod+Shift+7 move container to workspace number 7
    $mod+Shift+8 move container to workspace number 8
    $mod+Shift+9 move container to workspace number 9
    $mod+Shift+0 move container to workspace number 10

    # Move focused window to next workspace
    # Control+Alt+Right move container to workspace next
    # Control+Alt+Left  move container to workspace prev

    # Next / prev workspace
    Control+Alt+Right workspace next
    Control+Alt+Left  workspace prev

    # Split new window 
    $mod+b splith
    $mod+v splitv

    # Layout 
    # $mod+s layout toggle stacking
    # $mod+m layout toggle tabbed
    # $mod+r layout toggle split

    # Fullscreen mode
    $mod+f fullscreen

    # Toggle the current focus between tiling and floating mode
    $mod+Shift+f floating toggle

    # Focus between tiled and floating
    $mod+n focus mode_toggle

## Scratchpad
    
    # Move window to scratchpad
    $mod+Shift+minus move scratchpad
    # Restore window from scratchpad
    $mod+minus scratchpad show


## Other bindings

    # Volume management
    XF86AudioRaiseVolume exec $HOME/.local/bin/notifications/volume up
    XF86AudioLowerVolume exec $HOME/.local/bin/notifications/volume down
    XF86AudioMute        exec $HOME/.local/bin/notifications/volume mute
    XF86AudioMicMute     exec $HOME/.local/bin/notifications/microphone toggle
    # Same as above, but for external keyboard
    XF86AudioStop        exec $HOME/.local/bin/notifications/microphone toggle
    # Media control
    XF86AudioPrev        exec playerctl previous
    XF86AudioNext        exec playerctl next
    XF86AudioPlay        exec playerctl play-pause


    # Screenshots
    
    # Active window (don't work)
    # $mod+Shift+a exec grim -g "$(swaymsg -t get_tree | jq -r '.. | select(.focused?) | .rect | "\(.x),\(.y) \(.width)x\(.height)"')" - | wl-copy
    # Fullscreen 
    $mod+Shift+z exec grim - | wl-copy
    # Area
    $mod+Shift+s exec grim -g "$(slurp -b 00000080 -c 00000080)" - | wl-copy

    # Applications
    Control+Alt+s exec spotify
    Control+Alt+c exec google-chrome-stable
    Control+Alt+d exec discord
    $mod+e exec thunar

## Misc

    # Move focus to the parent container
    Alt+Tab focus parent

    # Exit sway
    Control+Alt+q exec killall sway
    
    # Resize mode toggle
    # $mod+r mode "resize"

    # Open terminal
    $mod+return exec alacritty

    # App launcher
    $mod+a exec ~/.config/rofi/launchers/launcher/launcher.sh

    # Close focused window
    $mod+q kill

    # Reload the configuration file
    $mod+Shift+r reload

    # Color picker
    $mod+Shift+c exec ~/.local/bin/scripts/colors/color_picker_wayland.sh

    # Lock session
    Control+Shift+l exec $HOME/.config/swaylock/lock_session.sh
}

### Window rules
