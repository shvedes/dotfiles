[global]

monitor                     = 0

# appearance
font                        = Monoscape 11
frame_width                 = 1
gap_size                    = 5
transparency                = 30
separator_height            = 4
separator_color             = foreground
corner_radius               = 0
padding                     = 4
horizontal_padding          = 4
origin                      = top-right
offset                      = 10x30
width                       = 400
height                      = 400


# icons
icon_theme                  = Stylish           # icon theme, which be used
icon_position               = left              # icon position
min_icon_size               = 64                # minimal icon size
max_icon_size               = 64                # maximum icon size
text_icon_padding           = 15                # padding between text and icon

# progress bar
progress_bar                = true
progress_bar_height         = 10
progress_bar_frame_width    = 1
progress_bar_min_width      = 150
progress_bar_max_width      = 300

# main settings
sort                        = yes               # sort notifications by urgency 
line_height                 = 2                 # spacing between lines
markup                      = full              # allow a small subset of html markup in notifications
format                      = "<b>%s</b>\n%b"   # format of notification
alignment                   = left              # text alignment 
timeout                     = 3                 # timeout for notifications
vertical_alignment          = center            # vertical alignment of message text and icon
ellipsize                   = end               # specify where to make an ellipsis in long lines
ignore_newline              = no                # ignore new lines in notifications
stack_duplicates            = false             # stack dublicate notifications (boolean)
indicate_hidden             = false             # show indicator of hidden notifications
show_indicators             = false             # show indicators (like link)
browser                     = /usr/bin/firefox  # browser for opening links
title                       = Dunst             # default title of window
class                       = dunst             # default class of window

mouse_left_click            = open_url, close_current, do_action

